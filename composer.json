{
  "name": "webniucom/webniu",
  "type": "project",
  "keywords": [
    "high performance",
    "http service"
  ],
  "homepage": "https://www.webniu.com",
  "license": "MIT",
  "description": "High performance HTTP Service Framework.",
  "authors": [
    {
      "name": "webniu",
      "email": "webniu@webniu.com",
      "homepage": "https://www.webniu.com",
      "role": "Developer"
    }
  ],
  "support": {
    "email": "admin@webniu.com",
    "issues": "https://github.com/webniucom/webniu/issues",
    "forum": "https://wenda.webniu.com/",
    "wiki": "https://webniu.com/doc",
    "source": "https://github.com/webniucom/webniu"
  },
  "require": {
    "php": ">=8.1",
    "workerman/webman-framework": "^2.1",
    "monolog/monolog": "^2.0",
    "webman/database": ">=2.1",
    "illuminate/pagination": ">=7.30",
    "illuminate/events": ">=7.30",
    "intervention/image": "^2.7",
    "webman/event": "^1.0",
    "webman/captcha": "^1.0.0",
    "guzzlehttp/guzzle": "^7.5",
    "laravel/serializable-closure": "^1.0",
    "ext-json": "*"
  },
  "suggest": {
    "ext-event": "For better performance. "
  },
  "autoload": {
    "psr-4": {
      "": "./",
      "app\\": "./app",
      "App\\": "./app",
      "app\\View\\Components\\": "./app/view/components"
    }
  },
  "scripts": {
    "post-package-install": [
      "support\\Plugin::install"
    ],
    "post-package-update": [
      "support\\Plugin::install"
    ],
    "pre-package-uninstall": [
      "support\\Plugin::uninstall"
    ],
    "post-create-project-cmd": [
      "support\\Setup::run"
    ],
    "setup-webman": [
      "support\\Setup::run"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
